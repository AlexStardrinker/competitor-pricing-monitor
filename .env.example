# Copy to `.env` and fill in for production. The demo runs without any of these.

# Claude — when set, monitor.py swaps from the mock interpreter to real Claude
ANTHROPIC_API_KEY=

# Email delivery (SMTP path — see monitor.py: send_email())
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
DIGEST_FROM=alerts@taskflow-pro.com
DIGEST_TO=founders@taskflow-pro.com

# Alternative: SendGrid / Postmark / Resend — drop in their REST client instead
